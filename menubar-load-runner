#!/usr/bin/env zsh
set -euo pipefail

readonly APP_CMD_NAME="menubar-load-runner/menubar-load-runner"

resolve_script_dir() {
  local source dir
  # In zsh functions, $0 is the function name; %x is the current script path.
  source="${(%):-%x}"

  if [[ "$source" != */* ]]; then
    source="$(command -v -- "$source" || true)"
    if [[ -z "$source" ]]; then
      print -u2 "$APP_CMD_NAME: unable to resolve script path"
      return 1
    fi
  fi

  while [[ -h "$source" ]]; do
    dir="$(cd -P -- "$(dirname -- "$source")" && pwd)"
    source="$(readlink -- "$source")"
    [[ "$source" != /* ]] && source="$dir/$source"
  done

  cd -P -- "$(dirname -- "$source")" && pwd
}

print_help() {
  cat <<EOF
Usage:
  $APP_CMD_NAME [dog-white|dog-black|horse-black|horse-white|chihiro|chihiro-white|chihiro-black|totoro|totoro-group-white|totoro-group-black|totoro-white|totoro-black|/path/to.gif] [--speed-multiplier <x>] [--load-source <cpu|memory|gpu|network|disk|fan|battery>] [--show-all-sources] [--label <off|value|text>] [--no-update-check] [--foreground|--no-detach]
  MENUBAR_LOAD_RUNNER_PATH=/path/to.gif $APP_CMD_NAME [--speed-multiplier <x>] [--load-source <cpu|memory|gpu|network|disk|fan|battery>] [--show-all-sources] [--label <off|value|text>] [--no-update-check] [--foreground|--no-detach]

Presets:
  dog-white   Built-in running dog (white)
  dog-black   Built-in running dog (black)
  horse-black  Built-in running horse (black)
  horse-white   Built-in running horse (white, default)
  chihiro  Built-in walking Chihiro (color)
  chihiro-white  Built-in walking Chihiro (white silhouette)
  chihiro-black  Built-in walking Chihiro (black silhouette)
  totoro  Built-in running Totoro
  totoro-group-white  Built-in Totoro group GIF (white, transparent)
  totoro-group-black  Built-in Totoro group GIF (black, transparent)
  totoro-white  Built-in running Totoro (white)
  totoro-black  Built-in running Totoro (black)

Options:
  --speed-multiplier <x>     Fixed speed (e.g. 0.5, 1.0, 1.5, 2.0)
  --load-source <src>        Reader driving the animation: cpu (default), memory, gpu, network, disk, fan, battery
                             (also via MENUBAR_LOAD_RUNNER_LOAD_SOURCE; unknown/unavailable -> cpu)
  --show-all-sources         Start with the menu's "Other Sources" list expanded, sampling every available
                             reader and showing each as a live row (also via MENUBAR_LOAD_RUNNER_SHOW_ALL=1;
                             click a row to switch source; the active source still drives the animation)
  --label <off|value|text>   Optional second menu-bar slot: 'value' shows the active source's live reading,
                             any other text is a fixed label (up to 24 chars), 'off' (default) shows nothing
                             (also via MENUBAR_LOAD_RUNNER_LABEL; switchable from the menu)
  --no-update-check          Skip the launch check for a newer release (also via MENUBAR_LOAD_RUNNER_UPDATE_CHECK=0)
  --foreground, --no-detach  Run attached to current shell (default is detached)
  --detach                   Run detached (default)
  --extra                    Allow launching a new instance even if one is already running
  -h, --help                 Show this help

Examples:
  $APP_CMD_NAME
  $APP_CMD_NAME dog-white
  $APP_CMD_NAME dog-black
  $APP_CMD_NAME horse-black
  $APP_CMD_NAME horse-white
  $APP_CMD_NAME chihiro
  $APP_CMD_NAME chihiro-white
  $APP_CMD_NAME chihiro-black
  $APP_CMD_NAME totoro
  $APP_CMD_NAME totoro-group-white
  $APP_CMD_NAME totoro-group-black
  $APP_CMD_NAME totoro-white
  $APP_CMD_NAME totoro-black
  $APP_CMD_NAME --load-source gpu
  $APP_CMD_NAME --load-source battery
  $APP_CMD_NAME --show-all-sources
  $APP_CMD_NAME --label value
  $APP_CMD_NAME dog-black --label BUILD
  $APP_CMD_NAME horse-black --speed-multiplier 1.2
  $APP_CMD_NAME --foreground horse-black
  MENUBAR_LOAD_RUNNER_PATH=/tmp/cat.gif $APP_CMD_NAME
EOF
}

main() {
  if ! command -v swift >/dev/null 2>&1; then
    print -u2 "$APP_CMD_NAME: swift command not found"
    exit 127
  fi

  local script_dir swift_module_cache
  local launch_detached=1
  local allow_extra=0
  local log_file pid
  local -a passthrough_args swift_cmd

  script_dir="$(resolve_script_dir)"
  swift_module_cache="${SWIFT_MODULE_CACHE:-/tmp/swift-module-cache}"

  passthrough_args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --foreground|--no-detach)
        launch_detached=0
        ;;
      --detach)
        launch_detached=1
        ;;
      --extra)
        allow_extra=1
        ;;
      *)
        passthrough_args+=("$1")
        ;;
    esac
    shift
  done
  set -- "${passthrough_args[@]}"

  # Preset keyword → GIF path resolution lives in Swift (MenuBarLoadRunnerApp.init), and the
  # preset profiles + default preset now live in gifs/presets.json, so the launcher forwards the
  # positional arg unchanged and only intercepts its own --help.
  if [[ $# -gt 0 ]]; then
    case "$1" in
      -h|--help)
        print_help
        exit 0
        ;;
    esac
  fi

  local swift_src="$script_dir/MenuBarLoadRunner.swift"
  local swift_bin="$script_dir/MenuBarLoadRunner"

  # -strict-concurrency=complete opts into full data-race checking (Swift 5 mode, so
  # violations surface as warnings rather than breaking the build). The source is annotated
  # @MainActor to satisfy it; see docs for the concurrency posture.
  if [[ ! -x "$swift_bin" ]] || [[ "$swift_src" -nt "$swift_bin" ]]; then
    if swiftc -O -strict-concurrency=complete "$swift_src" -o "$swift_bin" >/dev/null 2>&1; then
      swift_cmd=("$swift_bin" "$@")
    else
      mkdir -p -- "$swift_module_cache"
      swift_cmd=(swift -strict-concurrency=complete -module-cache-path "$swift_module_cache" "$swift_src" "$@")
    fi
  else
    swift_cmd=("$swift_bin" "$@")
  fi

  # Enforce singleton unless --extra is specified
  if (( ! allow_extra )); then
    # Match the compiled binary by its path — `/MenuBarLoadRunner` followed by a space
    # (it has args) or end-of-line (env-var mode, no positional). Args no longer carry a
    # `.gif` path now that Swift resolves preset keywords, so the old `.*\.gif` pattern
    # would miss keyword launches. The trailing `( |$)` keeps this from matching an editor
    # holding `MenuBarLoadRunner.swift` open, or a `swiftc`/`swift` build of the source.
    # (The interpreted `swift …/MenuBarLoadRunner.swift` fallback, used only when swiftc
    # fails, is intentionally not singleton-guarded.) pgrep -f excludes its own process;
    # the lowercase launcher path `menubar-load-runner` never matches this pattern.
    local existing_pids
    existing_pids=($(pgrep -f "/MenuBarLoadRunner( |$)" || true))
    if [[ ${#existing_pids[@]} -gt 0 ]]; then
      print -u2 "$APP_CMD_NAME: An instance of MenuBarLoadRunner is already running (PID: ${existing_pids[*]})."
      print -u2 "Use --extra to launch multiple instances."
      exit 1
    fi
  fi

  if (( launch_detached )); then
    log_file="${MENUBAR_LOAD_RUNNER_LOG_FILE:-/tmp/menubar-load-runner.log}"
    mkdir -p -- "$(dirname -- "$log_file")"
    MENUBAR_LOAD_RUNNER_BIN_NAME="$APP_CMD_NAME" \
      nohup "${swift_cmd[@]}" >>"$log_file" 2>&1 < /dev/null &
    pid=$!
    disown "$pid" 2>/dev/null || true
    print -- "$APP_CMD_NAME: started in background (pid=$pid, log=$log_file)"
    exit 0
  fi

  MENUBAR_LOAD_RUNNER_BIN_NAME="$APP_CMD_NAME" \
    exec "${swift_cmd[@]}"
}

main "$@"
